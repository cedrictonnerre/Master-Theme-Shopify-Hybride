# =============================================================================
# .env.example — Master Theme Shopify Hybride V1
# Copie ce fichier en .env et remplis les valeurs.
# ⚠️  Ne committe JAMAIS le fichier .env (déjà dans .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# SHOPIFY — Boutique de développement
# -----------------------------------------------------------------------------

# URL de ta boutique Shopify (sans https://)
SHOPIFY_STORE=mon-store.myshopify.com

# Token d'accès CLI (généré via : shopify auth login)
# Utilisé par Shopify CLI pour theme dev / theme push
SHOPIFY_CLI_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID du thème cible pour le push (optionnel — si omis, crée un nouveau thème)
# Récupère l'ID via : shopify theme list --store $SHOPIFY_STORE
SHOPIFY_THEME_ID=

# -----------------------------------------------------------------------------
# VITE — Serveur de développement
# -----------------------------------------------------------------------------

# Port du serveur Vite (doit correspondre au --proxy dans shopify theme dev)
VITE_PORT=5173

# -----------------------------------------------------------------------------
# MODE BOUTIQUE (référence — la valeur réelle est dans settings_data.json)
# -----------------------------------------------------------------------------

# landing  → Mono-produit (Hero Landing Page + Product Main)
# catalogue → Multi-produits (Collection Grid)
SHOP_MODE=landing

# -----------------------------------------------------------------------------
# ANALYTICS & TRACKING (Phase 3 — optionnel en MVP)
# -----------------------------------------------------------------------------

# Meta (Facebook) Pixel ID — pour les campagnes Meta Ads
META_PIXEL_ID=

# TikTok Pixel ID — pour les campagnes TikTok Ads
TIKTOK_PIXEL_ID=

# Conversion API (CAPI) — Token serveur Meta (améliore le tracking iOS)
META_CAPI_TOKEN=
