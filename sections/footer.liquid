<footer class="bg-background-secondary border-t border-border">
  <div class="section-container py-12 md:py-16">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: height: 80 }}"
            alt="{{ shop.name }}"
            height="40"
            loading="lazy"
          >
        {%- else -%}
          <span class="font-heading text-lg font-bold">{{ shop.name }}</span>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="text-text-light text-sm mt-3 leading-relaxed">{{ section.settings.tagline }}</p>
        {%- endif -%}

        <!-- Payment icons -->
        <div class="flex items-center gap-2 flex-wrap mt-5">
          {%- for payment_type in shop.enabled_payment_types -%}
            {{ payment_type | payment_type_svg_tag: class: 'h-6 opacity-60' }}
          {%- endfor -%}
        </div>
      </div>

      <!-- Navigation columns (up to 3) -->
      {%- for i in (1..3) -%}
        {%- assign menu_id = 'menu_' | append: i -%}
        {%- assign menu_title_id = 'menu_' | append: i | append: '_title' -%}
        {%- if section.settings[menu_id] != blank -%}
          <div>
            {%- if section.settings[menu_title_id] != blank -%}
              <h3 class="font-semibold text-xs uppercase tracking-widest mb-4">
                {{ section.settings[menu_title_id] }}
              </h3>
            {%- endif -%}
            <ul class="space-y-3">
              {%- for link in linklists[section.settings[menu_id]].links -%}
                <li>
                  <a
                    href="{{ link.url }}"
                    class="text-text-light text-sm hover:text-text transition-colors focus-ring rounded"
                  >
                    {{ link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-light text-xs">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.
      </p>
      {%- if section.settings.show_locale_selector and localization.available_countries.size > 1 -%}
        <form action="/localization" method="POST">
          {{ form.authenticity_token }}
          <input type="hidden" name="_method" value="PUT">
          <select name="country_code" class="text-xs border border-border rounded-theme px-2 py-1 bg-background focus:outline-none focus:ring-1 focus:ring-accent">
            {%- for country in localization.available_countries -%}
              <option
                value="{{ country.iso_code }}"
                {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
              >
                {{ country.name }} ({{ country.currency.iso_code }})
              </option>
            {%- endfor -%}
          </select>
        </form>
      {%- endif -%}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Pied de page",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Slogan",
      "default": "Qualité premium, livraison rapide."
    },
    {
      "type": "header",
      "content": "Colonne 1"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Titre colonne 1",
      "default": "Boutique"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu colonne 1",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Colonne 2"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Titre colonne 2",
      "default": "Aide & SAV"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu colonne 2"
    },
    {
      "type": "header",
      "content": "Colonne 3"
    },
    {
      "type": "text",
      "id": "menu_3_title",
      "label": "Titre colonne 3",
      "default": "Légal"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu colonne 3"
    },
    {
      "type": "header",
      "content": "Localisation"
    },
    {
      "type": "checkbox",
      "id": "show_locale_selector",
      "label": "Sélecteur de pays / devise",
      "default": false
    }
  ]
}
{% endschema %}
