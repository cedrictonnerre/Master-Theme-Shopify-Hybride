{% comment %}
  collection-grid.liquid
  Responsive product grid for catalogue mode.
  Column count is configurable per device via Theme Editor settings.
  Grid classes are safelisted in tailwind.config.js to prevent PurgeCSS removal.
{% endcomment %}

{%- assign cols_desktop = section.settings.columns_desktop | plus: 0 -%}
{%- assign cols_mobile = section.settings.columns_mobile | plus: 0 -%}
{%- assign products_per_page = section.settings.products_per_page | default: 12 -%}

{%- comment %} Build responsive grid classes from settings {%- endcomment -%}
{%- if cols_mobile == 1 -%}
  {%- assign grid_mobile = 'grid-cols-1' -%}
{%- else -%}
  {%- assign grid_mobile = 'grid-cols-2' -%}
{%- endif -%}

{%- case cols_desktop -%}
  {%- when 2 -%}
    {%- assign grid_desktop = 'md:grid-cols-2' -%}
  {%- when 4 -%}
    {%- assign grid_desktop = 'md:grid-cols-4' -%}
  {%- else -%}
    {%- assign grid_desktop = 'md:grid-cols-3' -%}
{%- endcase -%}

<section class="section-padding">
  <div class="section-container">
    {%- if collection.products.size == 0 -%}
      <div class="py-16 text-center text-text-light">
        <p class="text-lg">{{ 'collections.general.no_matches' | t }}</p>
      </div>
    {%- else -%}
      <div class="grid {{ grid_mobile }} {{ grid_desktop }} gap-4 md:gap-6">
        {%- for product in collection.products limit: products_per_page -%}
          <a
            href="{{ product.url }}"
            class="group block"
            aria-label="{{ product.title | escape }}"
          >
            <!-- Product image -->
            <div class="aspect-product rounded-theme overflow-hidden bg-background-secondary mb-3 relative">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                          {{ product.featured_image | image_url: width: 400 }} 400w,
                          {{ product.featured_image | image_url: width: 600 }} 600w"
                  sizes="(min-width: 768px) calc((var(--page-width) - 4rem) / {{ cols_desktop }}), calc((100vw - 2rem) / {{ cols_mobile }})"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  width="400"
                  height="533"
                >
              {%- else -%}
                <div class="w-full h-full flex items-center justify-center text-text-light">
                  {{ 'image' | placeholder_svg_tag: 'w-16 h-16' }}
                </div>
              {%- endif -%}

              {%- unless product.available -%}
                <span class="absolute top-2 right-2 bg-text text-background text-xs font-semibold px-2 py-0.5 rounded-full">
                  Épuisé
                </span>
              {%- endunless -%}
            </div>

            <!-- Product info -->
            {%- if section.settings.show_vendor and product.vendor != blank -%}
              <p class="text-text-light text-xs uppercase tracking-wider mb-0.5">{{ product.vendor }}</p>
            {%- endif -%}
            <p class="font-medium text-text text-sm leading-snug group-hover:text-accent transition-colors">{{ product.title }}</p>
            <p class="text-accent font-semibold text-sm mt-1">{{ product.price | money }}</p>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille Collection",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Produits par page",
      "min": 6,
      "max": 24,
      "step": 6,
      "default": 12
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonnes desktop",
      "options": [
        { "value": "2", "label": "2 colonnes" },
        { "value": "3", "label": "3 colonnes" },
        { "value": "4", "label": "4 colonnes" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes mobile",
      "options": [
        { "value": "1", "label": "1 colonne" },
        { "value": "2", "label": "2 colonnes" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Afficher la marque",
      "default": false
    }
  ]
}
{% endschema %}
