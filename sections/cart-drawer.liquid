{% comment %}
  cart-drawer.liquid
  Full-page cart drawer controlled by Alpine.store('cart').
  Rendered once in layout/theme.liquid, visible on all pages.
{% endcomment %}

<div
  x-data
  x-cloak
  class="relative z-50"
>
  <!-- Backdrop overlay -->
  <div
    x-show="$store.cart.open"
    x-transition:enter="transition ease-linear duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-linear duration-300"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-black/50 backdrop-blur-sm"
    @click="$store.cart.open = false"
    aria-hidden="true"
  ></div>

  <!-- Drawer panel -->
  <div
    x-show="$store.cart.open"
    x-transition:enter="transition ease-in-out duration-300 transform"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in-out duration-300 transform"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    @keydown.escape.window="$store.cart.open = false"
    class="fixed right-0 top-0 h-full w-full max-w-md bg-background shadow-2xl flex flex-col"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'cart.general.title' | t }}"
  >

    <!-- Drawer header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-border flex-shrink-0">
      <h2 class="font-heading text-xl font-semibold">
        {{ 'cart.general.title' | t }}
        <span
          x-show="$store.cart.itemCount > 0"
          x-text="`(${$store.cart.itemCount})`"
          class="text-text-light text-sm font-normal ml-1"
        ></span>
      </h2>
      <button
        @click="$store.cart.open = false"
        class="p-2 rounded-full hover:bg-background-secondary transition-colors focus-ring"
        :aria-label="'{{ 'accessibility.close_cart' | t }}'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <!-- Cart items (scrollable) -->
    <div class="flex-1 overflow-y-auto px-6 py-4 overscroll-contain">

      <!-- Loading state -->
      <div
        x-show="$store.cart.loading && $store.cart.isEmpty"
        class="flex items-center justify-center h-32"
      >
        <div class="spinner text-accent" aria-label="{{ 'general.loading' | t }}"></div>
      </div>

      <!-- Empty state -->
      <div
        x-show="!$store.cart.loading && $store.cart.isEmpty"
        class="flex flex-col items-center justify-center h-full text-center py-16"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-text-light mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 11H4L5 9z" />
        </svg>
        <p class="text-text-light text-lg font-medium mb-1">{{ 'cart.general.empty' | t }}</p>
        <button
          @click="$store.cart.open = false"
          class="mt-6 btn-primary"
        >
          {{ 'cart.general.continue_shopping' | t }}
        </button>
      </div>

      <!-- Items list -->
      <ul
        x-show="!$store.cart.isEmpty"
        class="divide-y divide-border"
        role="list"
      >
        <template x-for="item in $store.cart.items" :key="item.key">
          <li class="flex gap-4 py-5">

            <!-- Product image -->
            <a :href="item.url" class="w-20 h-20 flex-shrink-0 rounded-theme overflow-hidden bg-background-secondary block">
              <img
                :src="item.image"
                :alt="item.title"
                class="w-full h-full object-cover"
                loading="lazy"
                width="80"
                height="80"
              >
            </a>

            <!-- Item details -->
            <div class="flex-1 min-w-0">
              <a :href="item.url" class="font-medium text-sm leading-snug hover:text-accent transition-colors" x-text="item.product_title"></a>
              <p
                class="text-text-light text-xs mt-0.5"
                x-text="item.variant_title"
                x-show="item.variant_title && item.variant_title !== 'Default Title'"
              ></p>

              <!-- Price -->
              <p
                class="font-semibold text-sm mt-1"
                x-text="new Intl.NumberFormat('fr-FR', { style: 'currency', currency: $store.cart.currency || 'EUR' }).format(item.final_line_price / 100)"
              ></p>

              <!-- Quantity controls -->
              <div class="flex items-center gap-3 mt-2">
                <button
                  @click="$store.cart.update(item.key, item.quantity - 1)"
                  :disabled="$store.cart.loading"
                  class="w-7 h-7 flex items-center justify-center border border-border rounded-full hover:border-accent transition-colors text-sm disabled:opacity-40 disabled:cursor-not-allowed"
                  :aria-label="'{{ 'cart.general.quantity_decrease' | t }}'"
                >−</button>

                <span class="text-sm font-medium w-5 text-center tabular-nums" x-text="item.quantity" aria-live="polite"></span>

                <button
                  @click="$store.cart.update(item.key, item.quantity + 1)"
                  :disabled="$store.cart.loading"
                  class="w-7 h-7 flex items-center justify-center border border-border rounded-full hover:border-accent transition-colors text-sm disabled:opacity-40 disabled:cursor-not-allowed"
                  :aria-label="'{{ 'cart.general.quantity_increase' | t }}'"
                >+</button>

                <!-- Remove button -->
                <button
                  @click="$store.cart.remove(item.key)"
                  :disabled="$store.cart.loading"
                  class="ml-auto text-text-light hover:text-red-500 transition-colors disabled:opacity-40"
                  :aria-label="'{{ 'cart.general.remove' | t }}'"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            </div>

          </li>
        </template>
      </ul>
    </div>

    <!-- Drawer footer: totals + checkout -->
    <div
      x-show="!$store.cart.isEmpty"
      class="border-t border-border px-6 py-5 flex-shrink-0 space-y-4"
    >
      <!-- Loading overlay on footer -->
      <div
        x-show="$store.cart.loading"
        class="absolute inset-x-0 bottom-0 h-1 bg-accent/20 overflow-hidden"
      >
        <div class="h-full bg-accent animate-pulse"></div>
      </div>

      <!-- Subtotal -->
      <div class="flex justify-between items-center">
        <span class="text-text-light text-sm">{{ 'cart.general.subtotal' | t }}</span>
        <span
          class="font-semibold text-base"
          x-text="$store.cart.formattedTotal()"
          aria-live="polite"
        ></span>
      </div>

      <p class="text-xs text-text-light">{{ 'cart.general.shipping_at_checkout' | t }}</p>

      <!-- Checkout button -->
      <a
        href="/checkout"
        class="btn-primary w-full text-center"
        :class="$store.cart.loading && 'opacity-60 pointer-events-none'"
      >
        {{ 'cart.general.checkout' | t }}
      </a>

      <!-- View full cart link -->
      <a
        href="{{ routes.cart_url }}"
        @click="$store.cart.open = false"
        class="block w-full text-center py-3 border border-border text-text font-medium rounded-theme hover:border-accent transition-colors text-sm"
      >
        {{ 'cart.general.view_cart' | t }}
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Panier latéral",
  "settings": []
}
{% endschema %}
