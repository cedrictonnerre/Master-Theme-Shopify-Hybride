<header
  class="sticky top-0 z-40 bg-background border-b border-border"
  x-data
>
  <div class="max-w-page mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a
        href="{{ routes.root_url }}"
        class="flex-shrink-0 focus-ring rounded-theme"
        aria-label="{{ shop.name }}"
      >
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: height: 80 }}"
            alt="{{ shop.name }}"
            height="40"
            width="{{ section.settings.logo.width | times: 40 | divided_by: section.settings.logo.height | round }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- else -%}
          <span class="font-heading text-xl font-bold tracking-tight">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Navigation principale">
        {%- for link in section.settings.menu.links -%}
          {%- if link.links != blank -%}
            <div class="relative" x-data="{ open: false }">
              <button
                @click="open = !open"
                @keydown.escape.window="open = false"
                :aria-expanded="open"
                class="flex items-center gap-1 text-sm font-medium hover:text-accent transition-colors focus-ring rounded"
              >
                {{ link.title }}
                <svg
                  class="w-4 h-4 transition-transform duration-200"
                  :class="open && 'rotate-180'"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              <div
                x-show="open"
                x-cloak
                x-transition:enter="transition ease-out duration-100"
                x-transition:enter-start="opacity-0 scale-95 -translate-y-1"
                x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                x-transition:leave="transition ease-in duration-75"
                x-transition:leave-start="opacity-100 scale-100 translate-y-0"
                x-transition:leave-end="opacity-0 scale-95 -translate-y-1"
                @click.outside="open = false"
                class="absolute left-0 mt-2 w-52 bg-background rounded-theme shadow-lg border border-border py-1 z-50"
              >
                {%- for child_link in link.links -%}
                  <a
                    href="{{ child_link.url }}"
                    class="block px-4 py-2.5 text-sm hover:bg-background-secondary transition-colors {% if child_link.active %}text-accent font-medium{% endif %}"
                  >
                    {{ child_link.title }}
                  </a>
                {%- endfor -%}
              </div>
            </div>

          {%- else -%}
            <a
              href="{{ link.url }}"
              class="text-sm font-medium hover:text-accent transition-colors focus-ring rounded {% if link.active %}text-accent{% endif %}"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-1 md:gap-2">

        <!-- Cart trigger -->
        <button
          @click="$store.cart.open = true"
          class="relative p-2 hover:text-accent transition-colors focus-ring rounded-full"
          aria-label="{{ 'accessibility.open_cart' | t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 11H4L5 9z" />
          </svg>
          <!-- Cart item count badge -->
          <span
            x-show="$store.cart.itemCount > 0"
            x-text="$store.cart.itemCount"
            x-cloak
            class="absolute -top-0.5 -right-0.5 bg-accent text-white text-[10px] leading-none w-4 h-4 rounded-full flex items-center justify-center font-bold"
            aria-hidden="true"
          ></span>
        </button>

        <!-- Account (desktop only) -->
        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{{ routes.account_url }}"
            class="hidden md:flex p-2 hover:text-accent transition-colors focus-ring rounded-full"
            aria-label="{{ 'accessibility.my_account' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </a>
        {%- endif -%}

        <!-- Mobile menu toggle -->
        <button
          @click="$store.ui.toggleMobileMenu()"
          class="md:hidden p-2 hover:text-accent transition-colors focus-ring rounded-full"
          :aria-expanded="$store.ui.mobileMenuOpen"
          aria-controls="mobile-menu"
          :aria-label="$store.ui.mobileMenuOpen ? '{{ 'accessibility.close_menu' | t }}' : '{{ 'accessibility.open_menu' | t }}'"
        >
          <svg x-show="!$store.ui.mobileMenuOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg x-show="$store.ui.mobileMenuOpen" x-cloak class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <nav
    id="mobile-menu"
    x-show="$store.ui.mobileMenuOpen"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="md:hidden border-t border-border bg-background"
    aria-label="Navigation mobile"
  >
    <div class="max-w-page mx-auto px-4 py-4 space-y-1">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          @click="$store.ui.closeMobileMenu()"
          class="block px-4 py-3 text-sm font-medium rounded-theme hover:bg-background-secondary transition-colors {% if link.active %}text-accent{% endif %}"
          {% if link.active %}aria-current="page"{% endif %}
        >
          {{ link.title }}
        </a>
        {%- if link.links != blank -%}
          {%- for child_link in link.links -%}
            <a
              href="{{ child_link.url }}"
              @click="$store.ui.closeMobileMenu()"
              class="block px-8 py-2 text-sm text-text-light hover:bg-background-secondary transition-colors rounded-theme"
            >
              {{ child_link.title }}
            </a>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "En-tête",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu de navigation",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
