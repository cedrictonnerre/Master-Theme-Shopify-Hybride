{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money_without_trailing_zeros, shop: shop.name }}</title>
  {{ content_for_header }}
</head>
<body>
  <div style="text-align:center; padding: 2rem; font-family: sans-serif;">
    <h1>{{ shop.name }}</h1>
    <p>{{ 'gift_cards.issued.subtext' | t }}</p>
    <p style="font-size: 2rem; font-weight: bold; letter-spacing: 0.2em;">{{ gift_card.code | format_code }}</p>
    <p>{{ 'gift_cards.issued.initial_value' | t: initial_value: gift_card.initial_value | money }}</p>
    {% if gift_card.enabled == false or gift_card.expired %}
      <p>{{ 'gift_cards.issued.expired' | t }}</p>
    {% endif %}
  </div>
</body>
</html>
